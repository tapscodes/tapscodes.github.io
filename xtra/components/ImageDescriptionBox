/*
Params:
-src = image source path
-text = text for textbox
*/
const ImageTextBox = (props) => {
    return ( 
        <div className="box">
            <div className="image">
                <Image src={props.src}></Image>
            </div>
            <div className="textbox">
                <p>{props.text}</p>
            </div>
        </div>
     );
}
 
export default ImageTextBox;